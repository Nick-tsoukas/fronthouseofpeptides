# ── Runtime ──────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── Strapi ───────────────────────────────────────────────────────────────
# Production: https://api.quantumbiopeptides.com
STRAPI_URL=http://localhost:1337

# Full-access API token — generate in Strapi admin → Settings → API Tokens
# NEVER expose this to the browser
STRAPI_TOKEN=your_strapi_full_access_api_token_here

# ── SMTP / Email (Brevo) ──────────────────────────────────────────────────
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Sender shown on customer and owner emails — must be a verified Brevo sender
ORDER_FROM_EMAIL=Quantum Bio Peptides <orders@quantumbiopeptides.com>

# Internal address that receives new order request notifications
OWNER_ORDER_EMAIL=

# ── Owner Admin Auth ──────────────────────────────────────────────────────
# Password for the owner dashboard login (/owner/login)
OWNER_ADMIN_PASSWORD=

# Secret used to sign the owner session cookie — use openssl rand -base64 32
OWNER_SESSION_SECRET=

# ── Stripe ───────────────────────────────────────────────────────────────
# Parked — do not use until a compliant payment processor is selected.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── App ───────────────────────────────────────────────────────────────────
# Production: https://quantumbiopeptides.com
APP_URL=http://localhost:3000

# ── Moov ───────────────────────────────────────────────────────────────────
# Server-only API keys. Never expose the secret key to the browser.
MOOV_PUBLIC_KEY=
MOOV_SECRET_KEY=
MOOV_ACCOUNT_ID=
MOOV_MODE=test
MOOV_WEBHOOK_SECRET=

# ── Shippo ─────────────────────────────────────────────────────────────────
# Server-only API token. Never expose this to the browser.
SHIPPO_API_TOKEN=
SHIPPO_MODE=test

# Ship-from address used for all shipments
SHIPPING_FROM_NAME=
SHIPPING_FROM_COMPANY=
SHIPPING_FROM_STREET1=
SHIPPING_FROM_STREET2=
SHIPPING_FROM_CITY=
SHIPPING_FROM_STATE=
SHIPPING_FROM_ZIP=
SHIPPING_FROM_COUNTRY=US
SHIPPING_FROM_PHONE=
SHIPPING_FROM_EMAIL=

# Default parcel dimensions and weight
DEFAULT_PARCEL_LENGTH_IN=6
DEFAULT_PARCEL_WIDTH_IN=4
DEFAULT_PARCEL_HEIGHT_IN=2
DEFAULT_PARCEL_WEIGHT_OZ=6
