# ── Strapi ──────────────────────────────────────────────────────────────
# URL of your running Strapi backend
STRAPI_URL=http://localhost:1337

# Full-access API token — generate in Strapi admin → Settings → API Tokens
# Required for: webhook order creation, order lookup, server-side variant validation
STRAPI_TOKEN=your_strapi_full_access_api_token_here

# ── SMTP / Email (Brevo) ─────────────────────────────────────────────────
# Brevo SMTP relay settings
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Sender shown on customer and owner emails — must be a verified Brevo sender
ORDER_FROM_EMAIL=Quantum Bio Peptides <orders@quantumbiopeptides.com>

# Internal address that receives new order request notifications
OWNER_ORDER_EMAIL=

# ── Owner Admin Auth ─────────────────────────────────────────────────────
# Password for the owner dashboard login (/owner/login)
OWNER_ADMIN_PASSWORD=

# Secret used to sign the owner session cookie — use a long random string in production
OWNER_SESSION_SECRET=

# ── Stripe ───────────────────────────────────────────────────────────────
# Parked — do not use until a compliant payment processor is selected.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── App ──────────────────────────────────────────────────────────────────
APP_URL=http://localhost:3000
